# ─── PostgreSQL – Database ──────────────────────────────────────────────────────
# Set these from your database provider (Render, local Postgres, etc.)
NODE_ENV=production
DB_HOST=localhost
DB_PORT=5432
DB_NAME=GridironElite
DB_USER=postgres
DB_PASS=your-db-password
SESSION_SECRET=replace-with-a-long-random-secret
SESSION_COOKIE_SECURE=true

# Optional SSL controls:
# - DB_SSL=true forces SSL
# - DB_SSL=false disables SSL
# - DB_SSLMODE=require is treated as SSL on
# - DB_SSL_REJECT_UNAUTHORIZED=true enables strict certificate validation
DB_SSL=true
# DB_SSLMODE=require
DB_SSL_REJECT_UNAUTHORIZED=true

# Upload/optimization tuning:
# Max highlight video size in MB (server-side hard limit)
# MAX_HIGHLIGHT_VIDEO_MB=35
# FFmpeg optimization timeout in milliseconds
# FFMPEG_TIMEOUT_MS=180000

# ─── Backblaze B2 – user-upload storage ────────────────────────────────────────
#
# Create a Backblaze account, create a PRIVATE bucket, then create an
# Application Key with Read & Write permissions on that bucket.
# Copy these values from your Backblaze dashboard:

B2_KEY_ID=0012345abcdef000000000001
B2_APP_KEY=K001abcdefghijklmnopqrstuvwxyz0
B2_BUCKET_NAME=gridiron-elite-uploads

# ─── App URL – used to build email verification links ────────────────────────────
# Set this to the public-facing URL of your deployment (no trailing slash)
APP_URL=https://yourdomain.com
B2_BUCKET_REGION=us-west-004

# Optional: if you put a CDN (e.g. Cloudflare) in front of your bucket,
# set this to your CDN base URL. Leave blank to use the native B2 URL.
# B2_PUBLIC_URL=https://cdn.yourdomain.com

# ─── SMTP (email) – already used by the app ─────────────────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=you@gmail.com
